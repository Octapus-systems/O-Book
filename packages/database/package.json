{
  "name": "@o-book/database",
  "version": "1.0.0",
  "private": true,
  "description": "Database package with Prisma ORM",
  "main": "./lib/index.ts",
  "types": "./lib/index.ts",
  "scripts": {
    "build": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:test": "node scripts/test-connection.mjs",
    "db:doctor": "node scripts/db-doctor.mjs",
    "db:studio": "prisma studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.10.0",
    "prisma": "^5.7.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
